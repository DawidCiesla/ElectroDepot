@page "/components"
@inject ApiService ApiService
@inject AuthenticationService AuthService
@inject NavigationManager NavigationManager

<PageTitle>Components - ElectroDepot</PageTitle>

@if (!AuthService.IsAuthenticated)
{
    <p>Redirecting to login...</p>
}
else
{
    <div class="container-fluid mt-4">
        <div class="row mb-4">
            <div class="col">
                <h1><i class="bi bi-cpu-fill"></i> Components</h1>
            </div>
            <div class="col-auto">
                <button class="btn btn-primary" @onclick="ShowAddComponentModal">
                    <i class="bi bi-plus-circle"></i> Add Component
                </button>
            </div>
        </div>

        @if (isLoading)
        {
            <div class="text-center">
                <div class="spinner-border" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
        else if (!string.IsNullOrEmpty(loadError))
        {
            <div class="alert alert-danger" role="alert">
                @loadError
            </div>
        }
        else if (components == null || components.Count == 0)
        {
            <div class="alert alert-info" role="alert">
                No components found. Add your first component to get started!
            </div>
        }
        else
        {
            <div class="row">
                <div class="col-12">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Description</th>
                                    <th>Quantity</th>
                                    <th>Category</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var component in components)
                                {
                                <tr>
                                        <td>@component.Name</td>
                                        <td>@component.ShortDescription</td>
                                        <td>@GetOwnedQuantity(component)</td>
                                        <td>@GetCategoryName(component)</td>
                                        <td>
                                            <button class="btn btn-sm btn-info" @onclick='() => ViewComponent(component.ID)'>
                                                <i class="bi bi-eye"></i> View
                                            </button>
                                            <button class="btn btn-sm btn-danger" @onclick='() => DeleteComponent(component.ID)'>
                                                <i class="bi bi-trash"></i> Delete
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<ComponentDTO>? components;
    private Dictionary<int, string> categoryLookup = new();
    private Dictionary<int, int> ownedQuantities = new();
    private string? loadError;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated)
        {
            NavigationManager.NavigateTo("/login");
            return;
        }
        await LoadComponents();
    }

    private async Task LoadComponents()
    {
        isLoading = true;
        loadError = null;
        try
        {
            var userId = AuthService.CurrentUser?.ID;

            var componentsTask = ApiService.GetComponentsAsync();
            var categoriesTask = ApiService.GetCategoriesAsync();
            Task<List<OwnsComponentDTO>> ownedTask = Task.FromResult(new List<OwnsComponentDTO>());

            if (userId.HasValue)
            {
                ownedTask = ApiService.GetOwnedComponentsForUserAsync(userId.Value);
            }

            await Task.WhenAll(componentsTask, categoriesTask, ownedTask);

            components = componentsTask.Result;
            categoryLookup = categoriesTask.Result.ToDictionary(c => c.ID, c => c.Name);
            ownedQuantities = ownedTask.Result
                .GroupBy(o => o.ComponentID)
                .ToDictionary(group => group.Key, group => group.Sum(x => x.Quantity));
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading components: {ex.Message}");
            loadError = "Failed to load components. Please try again.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ShowAddComponentModal()
    {
        // TODO: Implement add component modal
        Console.WriteLine("Add component clicked");
    }

    private string GetCategoryName(ComponentDTO component)
    {
        return categoryLookup.TryGetValue(component.CategoryID, out var name) ? name : "Unknown";
    }

    private int GetOwnedQuantity(ComponentDTO component)
    {
        return ownedQuantities.TryGetValue(component.ID, out var quantity) ? quantity : 0;
    }

    private void ViewComponent(int id)
    {
        NavigationManager.NavigateTo($"/components/{id}");
    }

    private async Task DeleteComponent(int id)
    {
        try
        {
            var success = await ApiService.DeleteComponentAsync(id);
            if (success)
            {
                await LoadComponents();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting component: {ex.Message}");
        }
    }
}
